<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="All Tests" verbose="1" parallel="tests" thread-count="2">

    <!-- Listeners -->
    <listeners>
        <listener class-name="com.example.report.ExtentTestListener"/>
    </listeners>

    <test name="API Tests">
        <classes>
            <class name="com.example.api.tests.ReqResTests"/>
            <class name="com.example.api.tests.JsonPlaceholderTests"/>
        </classes>
    </test>

    <test name="UI Tests">
        <classes>
            <class name="com.example.ui.tests.LoginTests"/>
            <class name="com.example.ui.tests.FormAndElementsTests"/>
        </classes>
    </test>

</suite>
